      "name": "Register User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"123456\",\n  \"role\": \"admin\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/users/register",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api","users","register"]
        }
      },
      "response": []
    },
    {
      "name": "Login User",
